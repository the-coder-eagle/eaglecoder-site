<!-- 搜索弹窗 -->
<link rel="stylesheet" href="/pagefind/pagefind-ui.css">

<div id="search-dialog" style="display:none; position:fixed; inset:0; z-index:100000; display:none; align-items:flex-start; justify-content:center; padding-top:15vh;">
  <!-- 半透明背景遮罩 -->
  <div id="search-backdrop" style="position:absolute; inset:0; background:rgba(0,0,0,0.4);"></div>

  <!-- 搜索面板 -->
  <div style="position:relative; width:90%; max-width:560px; max-height:70vh; overflow-y:auto; border-radius:12px; box-shadow:0 20px 60px rgba(0,0,0,0.15); background:var(--color-bg); color:var(--color-text);">
    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 16px; border-bottom:1px solid var(--color-border);">
      <span style="font-weight:600; font-size:14px;">🔍 搜索全站</span>
      <button id="search-close" style="background:none; border:none; color:var(--color-text-secondary); cursor:pointer; font-size:18px;" aria-label="关闭搜索">✕</button>
    </div>
    <div id="pagefind-search" style="padding:16px;"></div>
  </div>
</div>

<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script>
  (function() {
    var dialog = document.getElementById('search-dialog');
    var backdrop = document.getElementById('search-backdrop');
    var closeBtn = document.getElementById('search-close');
    var container = document.getElementById('pagefind-search');
    var initialized = false;

    function initUI() {
      if (initialized || !container) return;
      initialized = true;
      try {
        new (window as any).PagefindUI({
          element: '#pagefind-search',
          baseUrl: '/pagefind/',
          showImages: false,
          showSubResults: true,
        });
      } catch (e) {
        container.innerHTML = '<p style="color:var(--color-text-secondary);font-size:14px;text-align:center;padding:20px;">搜索加载失败，请稍后重试</p>';
      }
    }

    function openSearch() {
      dialog.style.display = 'flex';
      initUI();
      setTimeout(function() {
        var input = container.querySelector('input');
        if (input) input.focus();
      }, 300);
    }

    function closeSearch() {
      dialog.style.display = 'none';
    }

    backdrop.addEventListener('click', closeSearch);
    closeBtn.addEventListener('click', closeSearch);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeSearch();
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      }
    });

    (window as any).__openSearch = openSearch;
  })();
</script>
