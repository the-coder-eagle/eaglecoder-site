---
// Giscus 评论区 — GitHub Discussions 驱动
export interface Props {
  term?: string;
}

const { term = 'pathname' } = Astro.props;
---

<div class="mt-12 pt-8 border-t" style="border-color: var(--color-border);">
  <h3 class="text-lg font-semibold mb-4">评论</h3>
  <div class="giscus"></div>
</div>

<script src="https://giscus.app/client.js"
  data-repo="the-coder-eagle/eaglecoder-site"
  data-repo-id="R_kgDOS8gHPg"
  data-category="Announcements"
  data-category-id="DIC_kwDOS8gHPs4C_VWM"
  data-mapping={term}
  data-strict="0"
  data-reactions-enabled="1"
  data-emit-metadata="0"
  data-input-position="top"
  data-theme="preferred_color_scheme"
  data-lang="zh-CN"
  data-loading="lazy"
  crossorigin="anonymous"
  async>
</script>
