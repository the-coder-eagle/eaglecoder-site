---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const projects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.order - a.data.order)
  .slice(0, 3);

import ProjectCard from '../components/ProjectCard.astro';
---

<Layout title="首页" description="EagleCoder 个人技术博客">
  <Nav />

  <!-- Hero -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #E0F2FE 0%, #BAE6FD 40%, #F3E8FF 100%);">
    <!-- 装饰：右上角模糊光斑 -->
    <div aria-hidden="true" class="absolute -top-20 -right-20 w-80 h-80 rounded-full opacity-30" style="background: radial-gradient(circle, var(--color-primary), transparent 70%);"></div>
    <!-- 装饰：左下角模糊光斑 -->
    <div aria-hidden="true" class="absolute -bottom-10 -left-10 w-60 h-60 rounded-full opacity-20" style="background: radial-gradient(circle, #7B4FBF, transparent 70%);"></div>

    <div class="max-w-5xl mx-auto px-4 pt-24 pb-16 relative z-10 fade-in">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4" style="color: #0C4A6E;">
        Hi，我是 <span style="color: var(--color-primary);">EagleCoder</span> 👋
      </h1>
      <p class="text-lg max-w-xl mb-6" style="color: #374151;">
        软件工程大一学生，热爱写代码、捣鼓项目。这里记录我的学习经验、项目作品和拾掇的文档。
      </p>
      <div class="flex gap-3">
        <a
          href="/posts"
          class="inline-flex items-center px-5 py-2.5 rounded-lg text-sm font-semibold text-white transition-all hover:shadow-lg"
          style="background: var(--color-primary);"
        >
          看文章 →
        </a>
        <a
          href="/projects"
          class="inline-flex items-center px-5 py-2.5 rounded-lg text-sm font-semibold transition-all border-2 hover:shadow-md"
          style="border-color: var(--color-primary); color: var(--color-primary);"
        >
          看项目 →
        </a>
      </div>
    </div>
  </section>

  <!-- 最新文章 -->
  <section class="max-w-5xl mx-auto px-4 py-10">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold">最新文章</h2>
      <a href="/posts" class="text-sm hover:underline" style="color: var(--color-primary);">查看全部 →</a>
    </div>

    {posts.length === 0 ? (
      <p style="color: var(--color-text-secondary);">还没有文章，马上开始写第一篇 ✍️</p>
    ) : (
      <div class="grid gap-4">
        {posts.map((post, i) => (
          <a
            href={`/posts/${post.id}`}
            class="flex rounded-lg border overflow-hidden transition-all hover:shadow-md fade-in"
            style="border-color: var(--color-border); background: var(--color-bg);"
          >
            <!-- 左侧紫色竖条 -->
            <div class="w-1 flex-shrink-0" style="background: var(--color-primary);"></div>
            <!-- 内容 -->
            <div class="p-5 flex-1">
              <div class="flex items-center gap-3 mb-2 flex-wrap">
                {i === 0 && (
                  <span class="text-xs px-2 py-0.5 rounded-full font-medium" style="background: var(--color-primary); color: white;">最新</span>
                )}
                <time class="text-xs font-mono" style="color: var(--color-text-secondary);">
                  {post.data.publishedAt.toISOString().slice(0, 10)}
                </time>
                {post.data.tags?.map((tag) => (
                  <span class="text-xs px-2 py-0.5 rounded-full" style="background: var(--color-bg-secondary); color: var(--color-primary);">
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="font-semibold text-lg">{post.data.title}</h3>
              <p class="text-sm mt-1" style="color: var(--color-text-secondary);">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <!-- 精选项目 -->
  <section class="max-w-5xl mx-auto px-4 py-10">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold">精选项目</h2>
      <a href="/projects" class="text-sm hover:underline" style="color: var(--color-primary);">查看全部 →</a>
    </div>

    {projects.length === 0 ? (
      <p style="color: var(--color-text-secondary);">还没有项目展示，去写点东西吧 👨‍💻</p>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {projects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            tech={project.data.tech}
            github={project.data.github}
            demo={project.data.demo}
            image={project.data.image}
          />
        ))}
      </div>
    )}
  </section>

  <Footer />
</Layout>
