---
// /challenge — 每日一题
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Layout from '../../layouts/Layout.astro';
import ChallengeView from '../../components/challenge/ChallengeView.astro';
import CodeEditor from '../../components/challenge/CodeEditor.astro';
import LanguageSelector from '../../components/challenge/LanguageSelector.astro';
import { getTodaysChallenge, getChallengeById, type SupportedLanguage } from '../../data/challenges';

// 支持 ?id=N 查询参数（历史题目跳转），默认今日题目
const idParam = Astro.url.searchParams.get('id');
const challenge = idParam ? (getChallengeById(parseInt(idParam)) || getTodaysChallenge()) : getTodaysChallenge();
const defaultLang: SupportedLanguage = 'c';
const challengeJson = JSON.stringify(challenge);
const showBackLink = !!idParam;
---

<Layout title={`每日一题 - ${challenge.title}`} description={challenge.title}>
  <Nav />

  <div class="max-w-7xl mx-auto px-4 py-8" data-pagefind-ignore>
    <!-- 顶部通栏 -->
    <div class="flex items-center justify-between mb-8 fade-in">
      <div>
        <p class="text-sm mb-1" style="color: var(--color-text-secondary);">
          🗓️ {idParam ? `题目 #${idParam}` : `每日一题 · ${new Date().toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}`}
        </p>
        {showBackLink && (
          <p class="text-xs" style="color: var(--color-text-secondary);">这是历史题目，<a href="/challenge" style="color: var(--color-primary);">← 回今日题目</a></p>
        )}
      </div>
      <div class="flex gap-3">
        <a
          href="/challenge/history"
          class="text-sm px-4 py-2 rounded-lg border transition-all hover:shadow-sm"
          style="border-color: var(--color-border); color: var(--color-text-secondary);"
        >
          📚 历史题目
        </a>
        <a
          href="/challenge/leaderboard"
          class="text-sm px-4 py-2 rounded-lg border transition-all hover:shadow-sm"
          style="border-color: var(--color-border); color: var(--color-text-secondary);"
        >
          🏆 排行榜
        </a>
      </div>
    </div>

    <!-- 两栏布局 -->
    <div class="grid lg:grid-cols-2 gap-8">
      <div class="fade-in">
        <ChallengeView challenge={challenge} />
      </div>

      <div>
        <div class="sticky top-20">
          <LanguageSelector active={defaultLang} />

          <CodeEditor language={defaultLang} initialCode={challenge.template[defaultLang]} />

          <!-- 用户名 + 提交按钮 -->
          <div class="mt-4 flex items-center gap-3">
            <div class="flex-1">
              <input
                id="username-input"
                type="text"
                placeholder="输入你的用户名"
                maxlength="30"
                autocomplete="off"
                class="w-full px-3 py-2 rounded-lg border text-sm transition-colors"
                style="border-color: var(--color-border); background: var(--color-bg); color: var(--color-text);"
              />
            </div>
            <button
              id="submit-btn"
              class="px-5 py-2 rounded-lg text-sm font-semibold text-white transition-all hover:shadow-md disabled:opacity-50 disabled:cursor-not-allowed"
              style="background: var(--color-primary);"
            >
              🚀 提交判题
            </button>
          </div>

          <!-- 判题结果显示 -->
          <div id="results-container" class="mt-4"></div>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script is:inline define:vars={{ challengeJson, defaultLang }}>
  (function() {
  let CHALLENGE = JSON.parse(challengeJson);
  const USERNAME_KEY = 'oj-username';
  const USER_ID_KEY = 'oj-user-id';

  // 生成或恢复用户唯一 ID（localStorage，防冒充）
  function getUserId() {
    let id = localStorage.getItem(USER_ID_KEY);
    if (!id) {
      id = 'u_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2, 8);
      localStorage.setItem(USER_ID_KEY, id);
    }
    return id;
  }
  const userId = getUserId();

  window.__challengeTemplates = CHALLENGE.template;
  window.__editorLang = defaultLang;
  window.__editorCode = CHALLENGE.template[defaultLang];

  // 优先从 API 加载今日题目（爬虫每天自动更新）
  fetch('/api/challenge/today')
    .then(r => r.json())
    .then(data => {
      if (data && data.title !== CHALLENGE.title) {
        // 替换题目数据和模板
        window.__challengeTemplates = data.template;
        window.__editorLang = defaultLang;
        window.__editorCode = data.template[defaultLang];
        CHALLENGE = data;
        document.title = '每日一题 - ' + data.title + ' | EagleCoder';

        // 重建整个挑战视图
        var view = document.querySelector('.challenge-view');
        if (view) {
          var diffClass = data.difficulty === 'easy' ? 'bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300' :
                          data.difficulty === 'medium' ? 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300' :
                          'bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300';
          var diffLabel = data.difficulty === 'easy' ? '简单' : data.difficulty === 'medium' ? '中等' : '困难';

          var tagsHtml = (data.tags || []).map(function(t) {
            return '<span class="text-xs px-2 py-0.5 rounded-full" style="background: var(--color-bg-secondary); color: var(--color-primary);">'+esc(t)+'</span>';
          }).join('');

          var examplesHtml = (data.examples || []).map(function(ex, i) {
            return '<div style="margin-bottom:12px; border-radius:8px; border:1px solid var(--color-border); padding:16px; background:var(--color-bg-secondary);"><div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;"><span style="font-size:12px; padding:2px 6px; border-radius:4px; font-family:monospace; background:var(--color-primary); color:white;">示例 '+(i+1)+'</span>'+(ex.explanation?'<span style="font-size:12px; color:var(--color-text-secondary);">'+esc(ex.explanation)+'</span>':'')+'</div><div style="font-size:14px;"><span style="font-family:monospace; font-weight:600; color:var(--color-text-secondary);">输入：</span><code style="font-family:monospace; padding:1px 6px; border-radius:4px; font-size:12px; background:var(--color-code-bg); color:#e2e8f0;">'+esc(ex.input)+'</code></div><div style="font-size:14px;"><span style="font-family:monospace; font-weight:600; color:var(--color-text-secondary);">输出：</span><code style="font-family:monospace; padding:1px 6px; border-radius:4px; font-size:12px; background:var(--color-code-bg); color:#e2e8f0;">'+esc(ex.output)+'</code></div></div>';
          }).join('');

          var tcRows = (data.testCases || []).map(function(tc, i) {
            return '<tr style="border-bottom:1px solid var(--color-border);"><td style="padding:8px; font-family:monospace; font-size:12px; color:var(--color-text-secondary);">'+(i+1)+'</td><td style="padding:8px; font-family:monospace; font-size:12px;">'+esc(tc.input)+'</td><td style="padding:8px; font-family:monospace; font-size:12px;">'+esc(tc.expected)+'</td><td style="padding:8px; font-size:12px; color:var(--color-text-secondary);">'+(tc.description||'—')+'</td></tr>';
          }).join('');

          var sourceHtml = data.source ? '<p style="font-size:12px; color:var(--color-text-secondary);">来源：<a href="'+esc(data.source.url)+'" target="_blank" rel="noopener" style="color:var(--color-primary);">'+esc(data.source.name)+'</a></p>' : '';

          view.innerHTML = '<div style="margin-bottom:24px;">' +
            '<div style="display:flex; align-items:center; gap:12px; margin-bottom:8px; flex-wrap:wrap;">' +
            '<h1 style="font-size:24px; font-weight:700;">'+esc(data.title)+'</h1>' +
            '<span class="text-xs px-2.5 py-0.5 rounded-full font-medium '+diffClass+'">'+diffLabel+'</span>' +
            '</div>' +
            '<div style="display:flex; flex-wrap:wrap; gap:6px; margin-bottom:12px;">'+tagsHtml+'</div>' +
            sourceHtml +
            '</div>' +
            '<div class="prose" style="margin-bottom:32px;">'+(data.description||'').replace(/\\n/g,'<br>')+'</div>' +
            '<div style="margin-bottom:32px;"><h3 style="font-size:14px; font-weight:600; margin-bottom:12px; color:var(--color-text-secondary);">📋 示例</h3>'+examplesHtml+'</div>' +
            '<div style="margin-bottom:32px;"><h3 style="font-size:14px; font-weight:600; margin-bottom:12px; color:var(--color-text-secondary);">🧪 测试用例 ('+(data.testCases||[]).length+' 个)</h3>' +
            '<div style="overflow-x:auto;"><table style="width:100%; font-size:14px; border-collapse:collapse;">' +
            '<thead><tr style="background:var(--color-bg-secondary);"><th style="text-align:left; padding:8px; border:1px solid var(--color-border);">#</th><th style="text-align:left; padding:8px; border:1px solid var(--color-border);">输入</th><th style="text-align:left; padding:8px; border:1px solid var(--color-border);">期望输出</th><th style="text-align:left; padding:8px; border:1px solid var(--color-border);">说明</th></tr></thead>' +
            '<tbody>'+tcRows+'</tbody></table></div></div>';
        }
      }
    })
    .catch(function() {});

  function esc(s) { if (!s) return ''; return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  const usernameInput = document.getElementById('username-input');
  const submitBtn = document.getElementById('submit-btn');
  const resultsContainer = document.getElementById('results-container');

  if (!usernameInput || !submitBtn || !resultsContainer) {
    console.warn('Challenge page: required DOM elements missing, aborting init');
    return;
  }

  // 恢复用户名
  const saved = localStorage.getItem(USERNAME_KEY);
  if (saved) usernameInput.value = saved;
  usernameInput.addEventListener('input', () => {
    localStorage.setItem(USERNAME_KEY, usernameInput.value.trim());
  });

  // 初始化当前语言标记
  window.__editorCurrentLang = defaultLang;

  /** 渲染判题结果 */
  function renderResults(data) {
    const { passed, total, score, status, results, username } = data;

    const statusIcons = {
      accepted: '✅', wrong_answer: '❌', time_limit_exceeded: '⏱️',
      runtime_error: '💥', compile_error: '🔧', error: '⚠️',
    };
    const statusLabels = {
      accepted: '通过', wrong_answer: '答案错误', time_limit_exceeded: '超时',
      runtime_error: '运行错误', compile_error: '编译错误', error: '系统错误',
    };

    let html = '';
    const isAllPassed = status === 'accepted';
    html += `<div class="rounded-lg p-4 mb-4" style="border: 2px solid ${isAllPassed ? '#22c55e' : '#ef4444'}; background: var(--color-bg-secondary);">`;
    html += `<div class="flex items-center justify-between mb-2">`;
    html += `<span class="text-lg font-bold">${isAllPassed ? '🎉 全部通过！' : '❌ 未通过'}</span>`;
    html += `<span class="text-2xl font-extrabold" style="color: ${isAllPassed ? '#22c55e' : '#ef4444'};">${score}/100</span>`;
    html += `</div>`;
    html += `<p class="text-sm" style="color: var(--color-text-secondary);">${passed}/${total} 个测试用例${username ? ' · 提交者：' + username : ''}</p>`;
    html += `</div>`;

    html += `<div class="border rounded-lg overflow-hidden" style="border-color: var(--color-border);">`;
    html += `<table class="w-full text-sm"><thead><tr style="background: var(--color-bg-secondary);">`;
    html += `<th class="text-left p-2 border-b" style="border-color: var(--color-border);">#</th>`;
    html += `<th class="text-left p-2 border-b" style="border-color: var(--color-border);">状态</th>`;
    html += `<th class="text-left p-2 border-b" style="border-color: var(--color-border);">期望</th>`;
    html += `<th class="text-left p-2 border-b" style="border-color: var(--color-border);">实际</th>`;
    html += `<th class="text-left p-2 border-b" style="border-color: var(--color-border);">耗时</th>`;
    html += `</tr></thead><tbody>`;

    for (const r of results) {
      const bg = r.status === 'accepted' ? 'transparent' : '#fef2f2';
      html += `<tr style="background: ${bg}; border-bottom: 1px solid var(--color-border);">`;
      html += `<td class="p-2 font-mono text-xs" style="color: var(--color-text-secondary);">${r.caseIndex}</td>`;
      html += `<td class="p-2 text-xs">${statusIcons[r.status] || '❓'} ${statusLabels[r.status] || r.status}</td>`;
      html += `<td class="p-2 font-mono text-xs">${escapeHtml(r.expected)}</td>`;
      html += `<td class="p-2 font-mono text-xs">${r.actual ? escapeHtml(r.actual) : (r.error ? '<span style="color:#ef4444;">'+escapeHtml(r.error)+'</span>' : '—')}</td>`;
      html += `<td class="p-2 font-mono text-xs" style="color: var(--color-text-secondary);">${r.time}</td>`;
      html += `</tr>`;
    }
    html += `</tbody></table></div>`;
    resultsContainer.innerHTML = html;
  }

  function escapeHtml(s) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  /** 提交判题 */
  submitBtn.addEventListener('click', async () => {
    const code = window.__editorGetCode?.() || '';
    const username = usernameInput.value.trim();

    if (!code.trim()) {
      resultsContainer.innerHTML = '<p style="color: #f59e0b; margin-top: 12px;">⚠️ 请先写点代码再提交</p>';
      return;
    }

    // 按钮 loading 状态
    submitBtn.disabled = true;
    submitBtn.textContent = '⏳ 判题中...';
    resultsContainer.innerHTML = '<p style="text-align: center; padding: 32px; color: var(--color-text-secondary);">⏳ 正在运行你的代码...</p>';

    try {
      const res = await fetch('/api/judge', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          language: window.__editorCurrentLang || defaultLang,
          code,
          challengeId: CHALLENGE.id,
          username: username || undefined,
          user_token: userId,
        }),
      });

      const data = await res.json();

      if (res.ok) {
        renderResults(data);
      } else {
        resultsContainer.innerHTML = `<p style="color: #ef4444; margin-top: 12px;">❌ ${data.error || '判题失败'}</p>`;
      }
    } catch (err) {
      resultsContainer.innerHTML = `<p style="color: #ef4444; margin-top: 12px;">❌ 连接判题服务失败：${err.message}</p>`;
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = '🚀 提交判题';
    }
  });

  // 回车快捷提交（Ctrl+Enter）
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
      submitBtn.click();
    }
  });

  })(); // IIFE end
</script>
