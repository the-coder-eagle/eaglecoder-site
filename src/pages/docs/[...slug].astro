---
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Giscus from '../../components/Giscus.astro';
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((d) => ({ params: { slug: d.id } }));
}

const { slug } = Astro.params;
const docs = await getCollection('docs');
const doc = docs.find((d) => d.id === slug)!;
const { Content } = await render(doc);
---

<Layout title={doc.data.title} description={doc.data.description}>
  <Nav />

  <article class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-8 fade-in">
      <h1 class="text-3xl font-bold">{doc.data.title}</h1>
      {doc.data.description && (
        <p class="mt-2" style="color: var(--color-text-secondary);">{doc.data.description}</p>
      )}
    </header>

    <div class="prose fade-in">
      <Content />
    </div>
  </article>

  <Footer />
</Layout>
