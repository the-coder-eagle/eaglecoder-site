---
// /lover — 私密聊天页面
// 独立页面，不使用 Layout（避免进站门禁 ID 冲突）
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>💕 | EagleCoder</title>
    <meta name="generator" content="Astro" />
    <style>
      :root {
        --color-bg: #ffffff;
        --color-bg-secondary: #f3f4f6;
        --color-text: #111827;
        --color-text-secondary: #6b7280;
        --color-border: #e5e7eb;
        --love-pink: #f093fb;
        --love-red: #f5576c;
      }
      html.dark {
        --color-bg: #0f172a;
        --color-bg-secondary: #1e293b;
        --color-text: #f1f5f9;
        --color-text-secondary: #94a3b8;
        --color-border: #334155;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: var(--color-bg);
        color: var(--color-text);
        min-height: 100vh;
      }
      .chat-bubble-ai p { margin: 0 !important; padding: 0 !important; line-height: 1.6; }
      .chat-bubble-ai br + br { display: none; }
    </style>
    <script>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <style>
      /* 进站门 — 遮住网站门禁 */
      #gate-overlay { display: none !important; }
    </style>
  </head>
  <body>

  <div class="max-w-lg mx-auto px-4" style="min-height: 100vh;" data-pagefind-ignore>

    <!-- ====== 密码门禁 ====== -->
    <div id="lover-gate" style="display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:90vh; text-align:center;">
      <div style="font-size:64px; margin-bottom:16px;">💕</div>
      <h1 style="font-size:22px; font-weight:700; margin-bottom:8px; color:var(--color-text);">只属于你的空间</h1>
      <p style="font-size:14px; color:var(--color-text-secondary); margin-bottom:24px;">输入密码进入</p>
      <input
        id="lover-password-input"
        type="password"
        placeholder="输入密码"
        autocomplete="off"
        style="width:260px; padding:12px 16px; border-radius:10px; border:1px solid var(--color-border); font-size:15px; text-align:center; background:var(--color-bg); color:var(--color-text); margin-bottom:12px; outline:none;"
      />
      <button
        id="lover-gate-btn"
        style="width:260px; padding:12px; border-radius:10px; font-size:15px; font-weight:600; border:none; cursor:pointer; background:linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color:white; transition:opacity 0.2s;"
      >
        进入 💕
      </button>
      <p id="lover-gate-error" style="font-size:13px; color:#ef4444; margin-top:12px; min-height:20px;"></p>
    </div>

    <!-- ====== 聊天界面（初始隐藏） ====== -->
    <div id="lover-chat" style="display:none; flex-direction:column; height:100vh;">
      <!-- 顶部状态栏 -->
      <div style="text-align:center; padding:14px; border-bottom:1px solid var(--color-border); font-size:15px; font-weight:600; color:var(--color-text); background:var(--color-bg);">
        💕 星姐姐
        <button id="lover-logout" style="position:absolute; right:16px; top:14px; background:none; border:none; color:var(--color-text-secondary); cursor:pointer; font-size:12px;">退出</button>
      </div>

      <!-- 消息列表 -->
      <div id="lover-messages" style="flex:1; overflow-y:auto; padding:16px 12px; display:flex; flex-direction:column; gap:12px;">
        <div style="display:flex; gap:8px; align-items:flex-start;">
          <div style="width:36px; height:36px; border-radius:50%; overflow:hidden; flex-shrink:0; background:linear-gradient(135deg, #f093fb, #f5576c);"><img src="/avatar-128.png" width="36" height="36" style="object-fit:cover;" alt="嗔子"></div>
          <div style="max-width:75%; padding:10px 14px; border-radius:4px 16px 16px 16px; background:var(--color-bg-secondary); color:var(--color-text); font-size:14px; line-height:1.6; word-break:break-word;">
            喵~ 姐姐你来啦 💕
          </div>
        </div>
      </div>

      <!-- 控制栏 -->
      <div style="display:flex; align-items:center; justify-content:center; gap:8px; padding:4px 12px; border-top:1px solid var(--color-border); flex-wrap:wrap;">
        <span style="font-size:11px; color:var(--color-text-secondary);">长度:</span>
        <button class="lov-len-btn active" data-len="medium" style="padding:3px 10px; border-radius:12px; border:1px solid #f5576c; background:#f5576c; color:white; font-size:11px; cursor:pointer;">中</button>
        <button class="lov-len-btn" data-len="short" style="padding:3px 10px; border-radius:12px; border:1px solid var(--color-border); background:transparent; color:var(--color-text-secondary); font-size:11px; cursor:pointer;">短</button>
        <button class="lov-len-btn" data-len="long" style="padding:3px 10px; border-radius:12px; border:1px solid var(--color-border); background:transparent; color:var(--color-text-secondary); font-size:11px; cursor:pointer;">长</button>
        <span style="color:var(--color-border);">|</span>
        <button id="lov-think-btn" style="padding:3px 10px; border-radius:12px; border:1px solid var(--color-border); background:transparent; color:var(--color-text-secondary); font-size:11px; cursor:pointer;">🧠</button>
        <button id="lov-search-btn" style="padding:3px 10px; border-radius:12px; border:1px solid var(--color-border); background:transparent; color:var(--color-text-secondary); font-size:11px; cursor:pointer;">🌐</button>
      </div>

      <!-- 输入区 -->
      <div style="padding:10px 12px; border-top:1px solid var(--color-border); display:flex; gap:8px; align-items:flex-end; background:var(--color-bg);">
        <button id="lover-clear-btn" style="background:none; border:none; color:var(--color-text-secondary); cursor:pointer; font-size:11px; padding:4px 8px; flex-shrink:0;">清空</button>
        <textarea
          id="lover-chat-input"
          rows="1"
          placeholder="说点什么..."
          maxlength="500"
          style="flex:1; padding:10px 14px; border-radius:20px; border:1px solid var(--color-border); font-size:14px; resize:none; background:var(--color-bg-secondary); color:var(--color-text); line-height:1.4; max-height:100px; outline:none;"
        ></textarea>
        <button
          id="lover-send-btn"
          style="width:44px; height:44px; border-radius:50%; border:none; background:linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color:white; font-size:18px; cursor:pointer; flex-shrink:0; transition:opacity 0.2s; display:flex; align-items:center; justify-content:center;"
        >
          ➤
        </button>
      </div>
    </div>

  </div>

  </body>
</html>

<script is:inline src="/marked.min.js"></script>
<script is:inline>
  (function() {
    if (typeof marked !== 'undefined') marked.setOptions({ breaks: true, gfm: true });
    var STORAGE_KEY = 'lover-token';
    var HISTORY_KEY = 'lover-chat-history';
    var MAX_HISTORY = 200;

    // DOMs
    var gate = document.getElementById('lover-gate');
    var chatContainer = document.getElementById('lover-chat');
    var passwordInput = document.getElementById('lover-password-input');
    var gateBtn = document.getElementById('lover-gate-btn');
    var gateError = document.getElementById('lover-gate-error');
    var messagesEl = document.getElementById('lover-messages');
    var chatInput = document.getElementById('lover-chat-input');
    var sendBtn = document.getElementById('lover-send-btn');
    var clearBtn = document.getElementById('lover-clear-btn');
    var logoutBtn = document.getElementById('lover-logout');
    var thinkBtn = document.getElementById('lov-think-btn');
    var lenBtns = document.querySelectorAll('.lov-len-btn');

    var currentLength = 'medium';
    var thinkingMode = false;
    var searchMode = false;

    lenBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        lenBtns.forEach(function(b) { b.classList.remove('active'); b.style.background='transparent'; b.style.color='var(--color-text-secondary)'; b.style.borderColor='var(--color-border)'; });
        btn.classList.add('active');
        btn.style.background = '#f5576c';
        btn.style.color = 'white';
        btn.style.borderColor = '#f5576c';
        currentLength = btn.getAttribute('data-len') || 'medium';
      });
    });

    thinkBtn.addEventListener('click', function() {
      thinkingMode = !thinkingMode;
      thinkBtn.style.background = thinkingMode ? '#f59e0b' : 'transparent';
      thinkBtn.style.color = thinkingMode ? 'white' : 'var(--color-text-secondary)';
      thinkBtn.style.borderColor = thinkingMode ? '#f59e0b' : 'var(--color-border)';
    });

    // 搜索切换
    var searchBtn = document.getElementById('lov-search-btn');
    if (searchBtn) {
      searchBtn.addEventListener('click', function() {
        searchMode = !searchMode;
        searchBtn.style.background = searchMode ? '#22c55e' : 'transparent';
        searchBtn.style.color = searchMode ? 'white' : 'var(--color-text-secondary)';
        searchBtn.style.borderColor = searchMode ? '#22c55e' : 'var(--color-border)';
      });
    }

    // State
    var chatHistory = [];
    var isLoading = false;
    var abortController = null;

    // === Password ===
    gateBtn.addEventListener('click', function() {
      var pwd = passwordInput.value.trim();
      if (!pwd) return;

      gateBtn.textContent = '...';
      gateBtn.disabled = true;

      fetch('/api/lover/verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pwd }),
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.ok) {
          localStorage.setItem(STORAGE_KEY, data.token);
          showChat();
        } else {
          gateError.textContent = '密码不对哦~';
          passwordInput.value = '';
          passwordInput.focus();
        }
      }).catch(function() {
        gateError.textContent = '连接失败，请稍后再试';
      }).finally(function() {
        gateBtn.textContent = '进入 💕';
        gateBtn.disabled = false;
      });
    });

    passwordInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') gateBtn.click();
    });

    // === Chat ===
    function showChat() {
      gate.style.display = 'none';
      chatContainer.style.display = 'flex';
      // Restore history
      try {
        var saved = JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]');
        chatHistory = saved;
        for (var i = 0; i < saved.length; i++) {
          appendBubble(saved[i].role, saved[i].content);
        }
      } catch(e) { chatHistory = []; }
      scrollToBottom();
      chatInput.focus();
    }

    function appendBubble(role, content, id) {
      var bubble = document.createElement('div');
      if (id) bubble.id = id;
      if (role === 'user') {
        bubble.style.cssText = 'display:flex; justify-content:flex-end;';
        bubble.innerHTML = '<div style="max-width:75%; padding:10px 14px; border-radius:16px 16px 4px 16px; background:linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color:white; font-size:14px; line-height:1.6; word-break:break-word;">' + esc(content) + '</div>';
      } else {
        bubble.style.cssText = 'display:flex; gap:8px; align-items:flex-start;';
        bubble.innerHTML = '<div style="width:36px; height:36px; border-radius:50%; overflow:hidden; flex-shrink:0; background:linear-gradient(135deg, #f093fb, #f5576c);"><img src="/avatar-128.png" width="36" height="36" style="object-fit:cover;" alt="嗔子"></div><div class="chat-bubble-ai" style="max-width:75%; padding:10px 14px; border-radius:4px 16px 16px 16px; background:var(--color-bg-secondary); color:var(--color-text); font-size:14px; line-height:1.6; word-break:break-word;">' + md(content) + '</div>';
      }
      messagesEl.appendChild(bubble);
      scrollToBottom();
    }

    function updateBubble(id, content) {
      var el = document.getElementById(id);
      if (!el) return;
      var divs = el.querySelectorAll('div');
      var textDiv = divs[divs.length - 1];
      if (textDiv) textDiv.innerHTML = md(content);
      scrollToBottom();
    }

    function scrollToBottom() {
      setTimeout(function() {
        messagesEl.scrollTop = messagesEl.scrollHeight;
      }, 50);
    }

    function md(text) { try { return marked.parse(text); } catch(e) { return esc(text); } }
    function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    // === Send ===
    function sendMessage() {
      var text = chatInput.value.trim();
      if (!text || isLoading) return;

      chatInput.value = '';
      chatInput.style.height = 'auto';

      // Add user
      chatHistory.push({ role: 'user', content: text });
      appendBubble('user', text);
      saveHistory();

      // Add AI placeholder
      var aiId = 'ai-' + Date.now();
      chatHistory.push({ role: 'assistant', content: '' });
      appendBubble('assistant', '...', aiId);

      isLoading = true;
      sendBtn.textContent = '⏳';
      abortController = new AbortController();

      fetch('/api/lover/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: chatHistory.slice(0, -1), thinking: thinkingMode, length: currentLength, search: searchMode }),
        signal: abortController.signal,
      }).then(function(response) {
        if (!response.ok) {
          return response.json().then(function(err) { throw new Error(err.error || 'error'); });
        }
        // SSE read
        var reader = response.body.getReader();
        var decoder = new TextDecoder();
        var fullContent = '';
        var buffer = '';

        function read() {
          reader.read().then(function(result) {
            if (result.done) {
              chatHistory[chatHistory.length - 1].content = fullContent;
              updateBubble(aiId, fullContent);
              saveHistory();
              isLoading = false;
              sendBtn.textContent = '➤';
              abortController = null;
              return;
            }
            buffer += decoder.decode(result.value, { stream: true });
            var lines = buffer.split('\n');
            buffer = lines.pop() || '';
            for (var i = 0; i < lines.length; i++) {
              var line = lines[i];
              if (line.indexOf('data: ') === 0) {
                var data = line.slice(6).trim();
                if (data === '[DONE]') continue;
                try {
                  var parsed = JSON.parse(data);
                  var delta = (parsed.choices && parsed.choices[0] && parsed.choices[0].delta && parsed.choices[0].delta.content) || '';
                  fullContent += delta;
                  updateBubble(aiId, fullContent);
                } catch(e) {}
              }
            }
            read();
          }).catch(function() {});
        }
        read();
      }).catch(function(err) {
        if (err.name !== 'AbortError') {
          updateBubble(aiId, '网络好像有点问题~ 姐姐等一下再试试 🐱');
          chatHistory[chatHistory.length - 1].content = 'error';
          saveHistory();
        }
        isLoading = false;
        sendBtn.textContent = '➤';
        abortController = null;
      });
    }

    function saveHistory() {
      try {
        var toSave = chatHistory.filter(function(m) { return m.content && m.content !== 'error'; }).slice(-MAX_HISTORY);
        localStorage.setItem(HISTORY_KEY, JSON.stringify(toSave));
      } catch(e) {}
    }

    // === Events ===
    sendBtn.addEventListener('click', sendMessage);
    chatInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });
    chatInput.addEventListener('input', function() {
      chatInput.style.height = 'auto';
      chatInput.style.height = Math.min(chatInput.scrollHeight, 100) + 'px';
    });
    clearBtn.addEventListener('click', function() {
      chatHistory = [];
      messagesEl.innerHTML = '';
      localStorage.removeItem(HISTORY_KEY);
      // Add welcome back
      var welcome = document.createElement('div');
      welcome.style.cssText = 'display:flex; gap:8px; align-items:flex-start;';
      welcome.innerHTML = '<div style="width:36px; height:36px; border-radius:50%; overflow:hidden; flex-shrink:0; background:linear-gradient(135deg, #f093fb, #f5576c);"><img src="/avatar-128.png" width="36" height="36" style="object-fit:cover;" alt="嗔子"></div><div style="max-width:75%; padding:10px 14px; border-radius:4px 16px 16px 16px; background:var(--color-bg-secondary); color:var(--color-text); font-size:14px; line-height:1.6; word-break:break-word;">喵~ 姐姐你来啦 💕</div>';
      messagesEl.appendChild(welcome);
    });
    logoutBtn.addEventListener('click', function() {
      localStorage.removeItem(STORAGE_KEY);
      chatHistory = [];
      messagesEl.innerHTML = '';
      localStorage.removeItem(HISTORY_KEY);
      chatContainer.style.display = 'none';
      gate.style.display = 'flex';
      passwordInput.value = '';
      passwordInput.focus();
    });

    // === Init ===
    if (localStorage.getItem(STORAGE_KEY)) {
      showChat();
    } else {
      passwordInput.focus();
    }
  })();
</script>
